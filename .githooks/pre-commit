#!/usr/bin/env bash
set -euo pipefail

# Pre-commit checks — mirrors the /deploy skill checks.
# Skip with: git commit --no-verify (use sparingly)

echo "Running pre-commit checks..."

echo "  [1/7] Lockfile freshness..."
bun install --frozen-lockfile > /dev/null 2>&1 || {
  echo "    Lockfile is out of date. Run 'bun install' and commit bun.lock."
  exit 1
}

echo "  [2/7] Schema drift check..."
cd apps/api && bun run db:check-drift
cd "$OLDPWD"

echo "  [3/7] Lint..."
bunx turbo lint

echo "  [4/7] Bobbin lint..."
bun run lint:bobbins

echo "  [5/7] Vercel compat..."
./scripts/check-vercel-compat.sh

echo "  [6/7] Typecheck..."
bun run typecheck

echo "  [7/7] Build..."
bun run build

echo "All pre-commit checks passed."
