{
  "name": "@bobbinry/monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Modular, open-source tools for writers and worldbuilders",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*",
    "bobbins/*",
    "infra/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "db:check-drift": "turbo db:check-drift",
    "verify": "turbo lint db:check-drift typecheck",
    "test": "turbo test",
    "start": "./dev-start.sh",
    "stop": "./dev-stop.sh",
    "stop:all": "./dev-stop.sh --containers",
    "status": "./dev-stop.sh --status",
    "create-bobbin": "node scripts/create-bobbin.js",
    "lint:bobbins": "bun scripts/lint-bobbins.ts",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "keywords": [
    "writing",
    "worldbuilding",
    "modular",
    "bobbins"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.9",
  "overrides": {
    "esbuild": ">=0.25.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "flatted": ">=3.4.0",
    "picomatch": ">=4.0.4",
    "lodash": ">=4.17.23",
    "handlebars": ">=4.7.9",
    "minimatch": ">=10.2.3",
    "brace-expansion": ">=5.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "zod": "^4.1.12"
  }
}
