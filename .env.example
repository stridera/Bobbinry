# ============================================================
# Shared
# ============================================================

# Postgres (API uses direct connection; shell has no DB access)
DATABASE_URL=postgres://bobbinry:bobbinry@localhost:5432/bobbinry

# JWT / internal auth (shared between shell and API)
API_JWT_SECRET=replace_with_strong_secret
INTERNAL_API_AUTH_TOKEN=replace_with_shared_internal_token
INTERNAL_API_AUTH_TOKEN_PREVIOUS=

# ============================================================
# Shell (Next.js / Vercel)
# ============================================================

NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=replace_with_strong_secret

# OAuth providers (buttons appear on login page when configured)
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# Public API URL (browser-side)
NEXT_PUBLIC_API_URL=http://localhost:4100

# Stripe (publishable key for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============================================================
# API (Fastify / Fly.io)
# ============================================================

# CORS / Origins
WEB_ORIGIN=http://localhost:3100
API_ORIGIN=http://localhost:4100

# Object Storage (MinIO local / Cloudflare R2 production)
S3_ENDPOINT=http://127.0.0.1:9100
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9100
S3_REGION=auto
S3_BUCKET=bobbinry
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminadmin

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CSP
CSP_ENABLE_STRICT=true

# ============================================================
# Email (Resend — API only)
# ============================================================

RESEND_API_KEY=
EMAIL_FROM=noreply@bobbinry.com
