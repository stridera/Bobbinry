# ============================================================
# Shared
# ============================================================

# Postgres (API uses direct connection; shell has no DB access)
DATABASE_URL=postgres://bobbinry:bobbinry@localhost:5432/bobbinry

# Optional: separate DB for API tests (defaults to a derived suffix of DATABASE_URL).
TEST_DATABASE_URL=

# JWT / internal auth (shared between shell and API)
API_JWT_SECRET=replace_with_strong_secret
INTERNAL_API_AUTH_TOKEN=replace_with_shared_internal_token
INTERNAL_API_AUTH_TOKEN_PREVIOUS=

# ============================================================
# Shell (Next.js / Vercel)
# ============================================================

NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=replace_with_strong_secret

# OAuth providers (Google sign-in shows when configured)
GOOGLE_ID=
GOOGLE_SECRET=

# Public API URL (browser-side)
NEXT_PUBLIC_API_URL=http://localhost:4100

# Public canonical app URL (used for OpenGraph metadata, sitemaps, etc.).
# Falls back to NEXTAUTH_URL when unset; required in production.
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Build identifier injected into the service worker so clients can detect
# new releases. Set automatically by CI; leave blank for local dev.
NEXT_PUBLIC_BUILD_ID=

# ============================================================
# API (Fastify / Fly.io)
# ============================================================

# CORS / Origins
WEB_ORIGIN=http://localhost:3100
API_ORIGIN=http://localhost:4100

# Email of the bootstrap admin user (used by seed-badges and admin checks).
ADMIN_EMAIL=strider@bobbinry.dev

# Object Storage (MinIO local / Cloudflare R2 production)
S3_ENDPOINT=http://127.0.0.1:9100
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9100
S3_REGION=auto
S3_BUCKET=bobbinry
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminadmin

# Stripe (server-side only — webhook + Connect platform fees)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUPPORTER_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_YEARLY_PRICE_ID=
# Platform fee percentage applied to author subscriptions (default 5).
PLATFORM_FEE_PERCENT=5

# CSP
CSP_ENABLE_STRICT=true

# ============================================================
# Email (Resend — API only)
# ============================================================

RESEND_API_KEY=
EMAIL_FROM=noreply@bobbinry.com
