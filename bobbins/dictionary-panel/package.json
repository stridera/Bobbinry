{
  "name": "@bobbinry/dictionary-panel",
  "version": "1.1.0",
  "description": "Native right-side panel with dictionary definitions and thesaurus",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./panels/*": "./src/panels/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.0-dev.20260318"
  }
}
