{
  "name": "@bobbinry/corkboard",
  "version": "1.0.0",
  "description": "Corkboard bobbin - visual board view for organizing content cards",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./views/*": "./src/views/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.1-rc"
  }
}
