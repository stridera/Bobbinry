{
  "name": "@bobbinry/bookworm-siege",
  "version": "1.0.0",
  "description": "Typing tower-defense game bobbin - every word you type fires a tower at the bookworms",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./panels/*": "./src/panels/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "6.0.3"
  }
}
