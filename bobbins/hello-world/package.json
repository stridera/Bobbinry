{
  "name": "@bobbinry/hello-world",
  "version": "1.0.0",
  "description": "Tutorial bobbin demonstrating SDK hooks, entity management, and theme-aware styling",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./views/*": "./src/views/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*",
    "@bobbinry/ui-components": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.0-dev.20260318"
  }
}
