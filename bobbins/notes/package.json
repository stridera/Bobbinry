{
  "name": "@bobbinry/notes",
  "version": "1.0.0",
  "description": "Rich research tool with folders, tagging, entity linking, and pinboard",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./views/*": "./src/views/*.tsx",
    "./panels/*": "./src/panels/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*",
    "@bobbinry/ui-components": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.0-dev.20260322"
  }
}
