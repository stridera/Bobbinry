{
  "name": "@bobbinry/discord-notifier",
  "version": "1.0.0",
  "description": "Announce chapter publishes to Discord channels via webhooks",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./panels/*": "./src/panels/*.tsx",
    "./actions/*": "./actions/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bobbinry/action-runtime": "workspace:*",
    "@bobbinry/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19"
  }
}
