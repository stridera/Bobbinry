{
  "name": "@bobbinry/entities",
  "version": "1.0.0",
  "description": "Configurable entity system for characters, spells, locations, and more",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./views/*": "./src/views/*.tsx",
    "./panels/*": "./src/panels/*.tsx",
    "./templates/*": "./src/templates/*.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*",
    "@bobbinry/ui-components": "workspace:*",
    "@tiptap/extension-character-count": "^3.6.2",
    "@tiptap/extension-placeholder": "^3.6.2",
    "@tiptap/pm": "^3.6.2",
    "@tiptap/react": "^3.6.2",
    "@tiptap/starter-kit": "^3.6.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "jest": "^30.3.0",
    "jsdom": "^29.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "6.0.1-rc"
  }
}
