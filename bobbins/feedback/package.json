{
  "name": "@bobbinry/feedback",
  "version": "1.0.0",
  "description": "View and manage reader annotations, error reports, and suggestions in the editor",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./panels/*": "./src/panels/*.tsx",
    "./extensions/*": "./src/extensions/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*",
    "@bobbinry/ui-components": "workspace:*",
    "@tiptap/core": "^3.6.2",
    "@tiptap/pm": "^3.6.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.3"
  }
}
