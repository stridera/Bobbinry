{
  "name": "@bobbinry/import",
  "version": "1.0.0",
  "description": "Import a manuscript from .docx, .epub, .pdf, .odt, .rtf, .md, .txt, or .html",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bobbinry/sdk": "workspace:*",
    "@bobbinry/types": "workspace:*",
    "@bobbinry/ui-components": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "6.0.3"
  }
}
