    "dev": "NODE_ENV=development bun --watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "../../scripts/jest.sh -c jest.unit.config.js --passWithNoTests",
